# =============================================================================
# BUDDY Voice Assistant - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Gemini API Configuration
# -----------------------------------------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (gemini-pro is recommended for general use)
GEMINI_MODEL=gemini-flash-latest

# -----------------------------------------------------------------------------
# Wake Word Configuration
# -----------------------------------------------------------------------------
# Wake word phrase (used by openWakeWord)
WAKE_WORD=hey_buddy

# Sensitivity for wake word detection (0.0 - 1.0, higher = more sensitive)
WAKE_WORD_SENSITIVITY=0.5

# -----------------------------------------------------------------------------
# Audio Configuration
# -----------------------------------------------------------------------------
# Microphone device index (use -1 for default, or specific index from arecord -l)
MIC_DEVICE_INDEX=-1

# Speaker device index (use -1 for default)
SPEAKER_DEVICE_INDEX=-1

# Sample rate for audio recording
AUDIO_SAMPLE_RATE=16000

# Audio chunk size (lower = more responsive, higher = more efficient)
AUDIO_CHUNK_SIZE=1024

# -----------------------------------------------------------------------------
# Speech Recognition Configuration
# -----------------------------------------------------------------------------
# Whisper model size: tiny, tiny.en, base, base.en, small, small.en
# For Raspberry Pi 4, use tiny.en or base.en
WHISPER_MODEL=tiny.en

# Compute type: int8 (fastest), float16, float32
# For Raspberry Pi, always use int8
WHISPER_COMPUTE_TYPE=int8

# Number of CPU threads for Whisper (2-4 recommended for Pi)
WHISPER_CPU_THREADS=2

# -----------------------------------------------------------------------------
# Text-to-Speech Configuration
# -----------------------------------------------------------------------------
# Path to Piper TTS executable
PIPER_PATH=/usr/local/bin/piper

# Path to Piper voice model
PIPER_VOICE_PATH=~/piper-voices/en_US-lessac-medium.onnx

# Speech rate multiplier (1.0 = normal, 1.2 = faster)
TTS_SPEECH_RATE=1.0

# -----------------------------------------------------------------------------
# Assistant Behavior
# -----------------------------------------------------------------------------
# Maximum response length (characters) - longer responses take more time
MAX_RESPONSE_LENGTH=500

# Timeout for listening after wake word (seconds)
LISTEN_TIMEOUT=5

# Enable debug logging
DEBUG=false

# Log file path
LOG_FILE=logs/buddy.log
