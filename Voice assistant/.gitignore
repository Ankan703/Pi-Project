# =============================================================================
# BUDDY Voice Assistant - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (CRITICAL - Never commit!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
.env.bak/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Model Files (large, download separately)
# -----------------------------------------------------------------------------
models/*.onnx
models/*.bin
models/*.pt
models/*.ggml
*.onnx
*.bin
!models/.gitkeep

# Piper voice files
piper-voices/

# Whisper model cache
~/.cache/huggingface/

# -----------------------------------------------------------------------------
# Audio Files
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.ogg
*.flac
recordings/
!sounds/*.wav

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/*.log
logs/*.txt
!logs/.gitkeep
*.log

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.cache

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
